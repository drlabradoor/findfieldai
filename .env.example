# ---- Supabase ----
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql+psycopg://postgres:password@db.xxxxx.supabase.co:5432/postgres
SUPABASE_STORAGE_BUCKET=places

# ---- Qdrant Cloud ----
QDRANT_URL=https://xxxxx.qdrant.tech
QDRANT_API_KEY=your-qdrant-key
QDRANT_COLLECTION=places
QDRANT_TEXT_VECTOR=text
QDRANT_IMAGE_VECTOR=image

# ---- Embeddings (BGE-M3 via HF Inference by default) ----
EMBEDDINGS_PROVIDER=huggingface
EMBEDDINGS_TEXT_MODEL=BAAI/bge-m3
EMBEDDINGS_IMAGE_MODEL=sentence-transformers/clip-ViT-B-32
HUGGINGFACE_API_KEY=hf_xxx
EMBEDDINGS_TEXT_DIM=1024
EMBEDDINGS_IMAGE_DIM=512

# ---- Chat provider (OpenAI-compatible endpoint) ----
CHAT_PROVIDER=openai_compat
CHAT_BASE_URL=https://api.groq.com/openai/v1
CHAT_API_KEY=your-key
CHAT_MODEL=llama-3.1-8b-instant

# ---- App ----
APP_ENV=dev
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:3000
